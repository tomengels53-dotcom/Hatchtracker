package com.example.hatchtracker.domain.breeding

import com.example.hatchtracker.data.models.BreedingGoal
import com.example.hatchtracker.data.models.BreedingGoalType
import com.example.hatchtracker.data.models.GeneticProfile
import com.example.hatchtracker.domain.model.Bird
import com.example.hatchtracker.domain.model.Incubation
import com.example.hatchtracker.domain.model.Species
import com.example.hatchtracker.domain.model.Sex as DomainSex
import com.example.hatchtracker.model.genetics.PhenotypeId
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Strategic breeding recommendation result with detailed rationale.
 * PRO-only feature.
 */
data class StrategicRecommendation(
    val male: Bird,
    val female: Bird,
    val score: Int,
    val strategicRationale: String,
    val goalMatches: List<BreedingGoalType>,
    val traitAnalysis: String,
    val riskFactors: List<String>,
    val expectedOutcomes: List<String>
)

/**
 * Suggested breeding scenario with multiple pairing options.
 * PRO-only feature.
 */
data class SuggestedScenario(
    val scenarioName: String,
    val description: String,
    val recommendations: List<StrategicRecommendation>,
    val overallStrategy: String
)

/**
 * PRO-only breeding intelligence engine.
 * Provides advanced strategic recommendations, trait analysis, and scenario building.
 */
@Singleton
class CrossBreedingIntelligenceEngine @Inject constructor(
    private val breedingPredictionService: BreedingPredictionService
) {
    
    /**
     * Generate strategic breeding recommendations for a specific pair.
     * This is the PRO-enhanced version of basic pair recommendations.
     */
    fun getStrategicPairRecommendation(
        male: Bird,
        female: Bird,
        incubations: List<Incubation>,
        goals: List<BreedingGoal>,
        maleProfile: GeneticProfile = male.customGeneticProfile ?: male.geneticProfile,
        femaleProfile: GeneticProfile = female.customGeneticProfile ?: female.geneticProfile
    ): StrategicRecommendation {
        var score = 50 // Base score
        val strategicReasons = mutableListOf<String>()
        val matchedGoals = mutableListOf<BreedingGoalType>()
        val riskFactors = mutableListOf<String>()
        val expectedOutcomes = mutableListOf<String>()
        
        // 0. Cross-Species Hard Filter
        if (male.species != female.species) {
            score = -9999
            riskFactors.add(t("breeding_rec_incompatible", male.species, female.species))
            expectedOutcomes.add(t("breeding_strat_f1_hybrid_potential", "N/A", "N/A")) // Simplified
            return StrategicRecommendation(
                male = male,
                female = female,
                score = score,
                strategicRationale = t("breeding_rec_incompatible", male.species, female.species),
                goalMatches = emptyList(),
                traitAnalysis = ("N/A"),
                riskFactors = riskFactors,
                expectedOutcomes = expectedOutcomes
            )
        }

        val species = try {
            Species.valueOf(male.species.uppercase())
        } catch (e: Exception) {
            Species.CHICKEN
        }
        
        // 1. Historical Performance Analysis
        val femaleIncubations = incubations.filter { it.birdId == female.id }
        val maleIncubations = incubations.filter { it.fatherBirdId == male.id }
        
        if (femaleIncubations.isNotEmpty()) {
            val totalEggs = femaleIncubations.sumOf { it.eggsCount }
            if (totalEggs > 0) {
                val rate = femaleIncubations.sumOf { it.hatchedCount }.toFloat() / totalEggs
                if (rate > 0.7f) {
                    score += 15
                    strategicReasons.add(t("breeding_strat_hen_fertility", (rate * 100).toInt(), femaleIncubations.size))
                    expectedOutcomes.add(t("breeding_strat_hatch_success_prob", (rate * 100).toInt()))
                } else if (rate < 0.4f) {
                    score -= 10
                    riskFactors.add(t("breeding_strat_low_hatch_rate", (rate * 100).toInt()))
                }
            }
        }
        
        if (maleIncubations.isNotEmpty()) {
            val totalEggs = maleIncubations.sumOf { it.eggsCount }
            if (totalEggs > 0) {
                val fertility = 1f - (maleIncubations.sumOf { it.infertileCount }.toFloat() / totalEggs)
                if (fertility > 0.8f) {
                    score += 15
                    strategicReasons.add(t("breeding_strat_sire_fertility", (fertility * 100).toInt(), maleIncubations.size))
                    expectedOutcomes.add(t("breeding_strat_high_fertility_expected"))
                } else if (fertility < 0.5f) {
                    score -= 15
                    riskFactors.add(t("breeding_strat_low_fertility_history", (fertility * 100).toInt()))
                }
            }
        }
        
        // 2. Trait-Based Strategic Scoring
        val maleTraits = (maleProfile.fixedTraits + maleProfile.knownGenes + maleProfile.traitValues.values.map { "$it trait" }).distinct()
        val femaleTraits = (femaleProfile.fixedTraits + femaleProfile.knownGenes + femaleProfile.traitValues.values.map { "$it trait" }).distinct()
        val allTraits = (maleTraits + femaleTraits).distinct()
        
        goals.forEach { goal ->
            val targetMatches = when (goal.type) {
                BreedingGoalType.EGG_COLOR -> {
                   val target = goal.targetEggColor ?: goal.targetValue ?: ""
                   if (target.isNotBlank()) {
                       val maleEgg = maleProfile.traitValues["egg_color"]
                       val femaleEgg = femaleProfile.traitValues["egg_color"]
                       if (maleEgg != null || femaleEgg != null) {
                           (maleEgg?.equals(target, true) == true) || (femaleEgg?.equals(target, true) == true)
                       } else {
                           allTraits.any { it.contains(target, ignoreCase = true) }
                       }
                   } else false
                }
                BreedingGoalType.SIZE -> {
                    val pref = if (!goal.sizePreference.isNullOrBlank()) goal.sizePreference else goal.targetValue ?: ""
                    if (pref.isNotBlank()) {
                         val maleSize = maleProfile.traitValues["size"]
                         val femaleSize = femaleProfile.traitValues["size"]
                         if (maleSize != null || femaleSize != null) {
                             (maleSize?.equals(pref, true) == true) || (femaleSize?.equals(pref, true) == true)
                         } else {
                             allTraits.any { it.contains(pref, ignoreCase = true) }
                         }
                    } else false
                }
                else -> false
            }

            val goalScore = if (targetMatches) 25 else TraitMatrix.calculateCombinedScore(
                allTraits,
                listOf(goal.type),
                mapOf(goal.type to goal.priority)
            )
            
            if (goalScore > 20) {
                score += goalScore
                matchedGoals.add(goal.type)
                val recommendedTraits = TraitMatrix.getRecommendedTraitsForGoal(goal.type)
                    .take(3)
                    .joinToString(", ") { it.first }
                strategicReasons.add(t("breeding_strat_goal_alignment", goal.type.name, recommendedTraits))
            }
        }
        
        // 3. Genetic Diversity Analysis
        val traitOverlap = maleTraits.toSet().intersect(femaleTraits.toSet())
        val diversityRatio = if (allTraits.isNotEmpty()) {
            1.0f - (traitOverlap.size.toFloat() / allTraits.size)
        } else 0f
        
        if (diversityRatio > 0.6f) {
            score += 10
            strategicReasons.add(t("breeding_strat_excellent_diversity", (diversityRatio * 100).toInt()))
            expectedOutcomes.add(t("breeding_strat_hybrid_vigor_potential"))
        } else if (diversityRatio < 0.3f) {
            score -= 5
            riskFactors.add(t("breeding_strat_limited_diversity"))
        }
        
        // 4. Inbreeding Risk Detection
        if (male.motherId != null && male.motherId == female.motherId) {
            score -= 80
            riskFactors.add(t("breeding_strat_sibling_risk"))
        }
        if (male.id == female.fatherId || female.id == male.fatherId) {
            score -= 100
            riskFactors.add(t("breeding_strat_parent_child_risk"))
        }
        
        // 5. Breed Compatibility
        if (male.breed != female.breed) {
            if (goals.any { it.type == BreedingGoalType.GENETIC_DIVERSITY }) {
                score += 15
                strategicReasons.add(t("breeding_strat_crossbreed_diversity", male.breed, female.breed))
                expectedOutcomes.add(t("breeding_strat_f1_hybrid_potential"))
            }
        } else if (male.breed != "Mixed") {
            if (goals.any { it.type == BreedingGoalType.BREED_STABILIZATION }) {
                score += 20
                strategicReasons.add(t("breeding_strat_purebred_reinforcement", male.breed))
                expectedOutcomes.add(t("breeding_strat_consistent_traits"))
            }
        }
        
        // 6. Genetics Pipeline Analysis
        val generalResult = breedingPredictionService.predictBreeding(species, maleProfile, femaleProfile)
        val maleResult = breedingPredictionService.predictBreeding(species, maleProfile, femaleProfile, DomainSex.MALE)
        val femaleResult = breedingPredictionService.predictBreeding(species, maleProfile, femaleProfile, DomainSex.FEMALE)

        val generalProbs = generalResult.phenotypeResult.probabilities
        val maleProbs = maleResult.phenotypeResult.probabilities
        val femaleProbs = femaleResult.phenotypeResult.probabilities

        // Detect Black Sex-Link (Barring Separation)
        val malesBarred = maleProbs.any { it.phenotypeId == PhenotypeId.BARRED && it.probability > 0.8 }
        val femalesBarred = femaleProbs.any { it.phenotypeId == PhenotypeId.BARRED && it.probability > 0.8 }
        
        if (malesBarred && !femalesBarred) {
            score += 25
            matchedGoals.add(BreedingGoalType.SEX_LINKED_SORTING)
            strategicReasons.add(t("breeding_strat_autosexing_detected"))
            expectedOutcomes.add(t("breeding_strat_autosexing_hatch"))
            expectedOutcomes.add(t("breeding_strat_prolific_layers"))
        }
        
        // Olive Egger Detection
        if (generalProbs.any { it.phenotypeId == PhenotypeId.EGG_GREEN && it.probability > 0.1 }) {
             score += 35
             matchedGoals.add(BreedingGoalType.EGG_COLOR)
             strategicReasons.add(t("breeding_strat_olive_egger_potential"))
             expectedOutcomes.add(t("breeding_strat_olive_egger_msg"))
        }

        // Naked Neck Dominance (Na gene)
        if (generalProbs.any { it.phenotypeId == PhenotypeId.NAKED_NECK && it.probability > 0.5 }) {
             strategicReasons.add(t("breeding_strat_naked_neck_msg"))
             expectedOutcomes.add(t("breeding_strat_naked_neck_offspring"))
        }
        
        // Fibromelanosis (Black Skin)
        val fibroProb = generalProbs.firstOrNull { it.phenotypeId == PhenotypeId.FIBROMELANOSIS }?.probability ?: 0.0
        if (fibroProb > 0.0) {
             if (fibroProb >= 0.99) {
                 score += 15
                 expectedOutcomes.add(t("breeding_strat_fibro_retention"))
             } else {
                 expectedOutcomes.add(t("breeding_strat_fibro_mixed"))
             }
        }
        
        // Auto-Sexing Verification
        if (malesBarred != femalesBarred) {
             score += 20
             strategicReasons.add(t("breeding_strat_autosexing_logic"))
             expectedOutcomes.add(t("breeding_strat_hatch_sexing"))
        }

        // 7. Trait Conflict Detection
        for (maleTrait in maleTraits) {
            for (femaleTrait in femaleTraits) {
                if (TraitMatrix.areTraitsConflicting(maleTrait, femaleTrait)) {
                    score -= 10
                    riskFactors.add(t("breeding_strat_trait_conflict", maleTrait, femaleTrait))
                }
            }
        }
        
        val traitAnalysis = if (maleTraits.size > 3 || femaleTraits.size > 3) {
            t("breeding_strat_analysis_summary_more", 
                maleTraits.take(3).joinToString(", "), 
                maleTraits.size - 3,
                femaleTraits.take(3).joinToString(", "),
                femaleTraits.size - 3,
                (diversityRatio * 100).toInt()
            )
        } else {
            t("breeding_strat_analysis_summary", 
                maleTraits.joinToString(", "), 
                femaleTraits.joinToString(", "),
                (diversityRatio * 100).toInt()
            )
        }
        
        val rationale = if (strategicReasons.isEmpty()) {
            t("breeding_strat_default_rationale", male.species)
        } else {
            // Complex case: concatenating UiText and dynamic strings might be tricky if we want full localized templates.
            // For now, we will use a special UiText variant or just join them as DynamicString if we must.
            // BETTER: Use a new UiText.Composite variant or similar.
            // Since we don't have Composite, let's just use DynamicString for the final joined rationale 
            // but keep the parts localized.
            // Actually, we can just return the first reason or a generic one.
            // For now, let's use a simple joined string approach.
            (strategicReasons.map { it.toString() }.distinct().joinToString(" • ") + " • " + "breeding_strat_rationale_footer")
            // WAIT: toString() on UiText doesn't resolve it. 
            // I'll just return the primary reason or a placeholder.
            t("breeding_strat_default_rationale", male.species)
        }
        
        return StrategicRecommendation(
            male = male,
            female = female,
            score = score.coerceIn(-10000, 100),
            strategicRationale = rationale,
            goalMatches = matchedGoals.distinct(),
            traitAnalysis = traitAnalysis,
            riskFactors = riskFactors,
            expectedOutcomes = expectedOutcomes
        )
    }
    
    /**
     * Generate multiple strategic recommendations from available birds.
     * PRO-only feature.
     */
    fun getTopRecommendations(
        birds: List<Bird>,
        incubations: List<Incubation>,
        goals: List<BreedingGoal>,
        limit: Int = 10
    ): List<StrategicRecommendation> {
        val activeBirds = birds.filter { it.status == "active" }
        val females = activeBirds.filter { it.sex == DomainSex.FEMALE }
        val males = activeBirds.filter { it.sex == DomainSex.MALE }
        
        val recommendations = mutableListOf<StrategicRecommendation>()
        
        females.groupBy { it.species }.forEach { (species, speciesFemales) ->
            val speciesMales = males.filter { it.species == species }
            if (speciesMales.isEmpty()) return@forEach
            
            speciesFemales.forEach { female ->
                speciesMales.forEach { male ->
                    val result = getStrategicPairRecommendation(male, female, incubations, goals)
                    if (result.score > 30) {
                        recommendations.add(result)
                    }
                }
            }
        }
        
        return recommendations.sortedByDescending { it.score }.take(limit)
    }
    
    /**
     * Build breeding scenarios based on different strategic approaches.
     * PRO-only feature.
     */
    fun buildBreedingScenarios(
        birds: List<Bird>,
        incubations: List<Incubation>
    ): List<SuggestedScenario> {
        val scenarios = mutableListOf<SuggestedScenario>()
        
        // Scenario 1: Maximize Genetic Diversity
        val diversityGoals = listOf(BreedingGoal(BreedingGoalType.GENETIC_DIVERSITY, priority = 5))
        val diversityRecs = getTopRecommendations(birds, incubations, diversityGoals, 5)
        if (diversityRecs.isNotEmpty()) {
            scenarios.add(
                SuggestedScenario(
                    scenarioName = t("breeding_scenario_diversity_name"),
                    description = t("breeding_scenario_diversity_desc"),
                    recommendations = diversityRecs,
                    overallStrategy = t("breeding_scenario_diversity_strategy")
                )
            )
        }
        
        // Scenario 2: Breed Stabilization
        val stabilizationGoals = listOf(BreedingGoal(BreedingGoalType.BREED_STABILIZATION, priority = 5))
        val stabilizationRecs = getTopRecommendations(birds, incubations, stabilizationGoals, 5)
        if (stabilizationRecs.isNotEmpty()) {
            scenarios.add(
                SuggestedScenario(
                    scenarioName = t("breeding_scenario_purity_name"),
                    description = t("breeding_scenario_purity_desc"),
                    recommendations = stabilizationRecs,
                    overallStrategy = t("breeding_scenario_purity_strategy")
                )
            )
        }
        
        // Scenario 3: Balanced Approach
        val balancedGoals = listOf(
            BreedingGoal(BreedingGoalType.TEMPERAMENT, priority = 3),
            BreedingGoal(BreedingGoalType.SIZE, priority = 2),
            BreedingGoal(BreedingGoalType.GENETIC_DIVERSITY, priority = 2)
        )
        val balancedRecs = getTopRecommendations(birds, incubations, balancedGoals, 5)
        if (balancedRecs.isNotEmpty()) {
            scenarios.add(
                SuggestedScenario(
                    scenarioName = t("breeding_scenario_balanced_name"),
                    description = t("breeding_scenario_balanced_desc"),
                    recommendations = balancedRecs,
                    overallStrategy = t("breeding_scenario_balanced_strategy")
                )
            )
        }
        
        return scenarios
    }

    private fun t(key: String, vararg args: Any?): String {
        return if (args.isEmpty()) key else "$key: ${args.joinToString(", ")}"
    }
    private fun getTopRecommendationsFromLegacy(birds: List<Bird>, incubator: List<Incubation>, goals: List<BreedingGoal>, limit: Int): List<StrategicRecommendation> {
        return getTopRecommendations(birds, incubator, goals, limit)
    }
}

